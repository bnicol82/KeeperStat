# Vercel (API) — Neon pooled connection string, set via `vercel env add DATABASE_URL`
DATABASE_URL=postgres://user:password@ep-example.neon.tech/neondb?sslmode=require

# Vite (frontend) — base URL of the deployed Vercel API
VITE_API_BASE_URL=https://keeperstat-api.vercel.app

# Vite (frontend) — base URL of the Neon Auth instance backing real accounts
# (demo mode doesn't need this; only used by authClient.js)
VITE_NEON_AUTH_URL=https://your-project.neonauth.dev
